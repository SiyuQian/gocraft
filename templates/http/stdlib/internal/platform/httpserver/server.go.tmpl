package httpserver

import (
	"log/slog"
	"net/http"

	"{{.Module}}/internal/health"
	"{{.Module}}/internal/pets"
	"{{.Module}}/internal/platform/config"
	"{{.Module}}/internal/platform/db"
	"{{.Module}}/internal/platform/obs"
)

func New(cfg config.Config, logger *slog.Logger, pool *db.Pool) *http.Server {
	mux := http.NewServeMux()
	mux.HandleFunc("GET /healthz", health.Healthz)

	if pool != nil {
		h := pets.NewHandler(pets.NewService(pets.NewRepo(pool)), stdlibID)
		h.Register(muxRouter{mux})
	}
	return &http.Server{Addr: cfg.Addr, Handler: obs.Middleware(withRecover(logger, mux))}
}

type muxRouter struct{ m *http.ServeMux }

func (s muxRouter) Handle(method, pattern string, h http.HandlerFunc) {
	s.m.HandleFunc(method+" "+pattern, h)
}

func stdlibID(r *http.Request, name string) string { return r.PathValue(name) }

func withRecover(logger *slog.Logger, h http.Handler) http.Handler {
	return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		defer func() {
			if rec := recover(); rec != nil {
				logger.Error("panic", "err", rec, "path", r.URL.Path)
				http.Error(w, "internal server error", http.StatusInternalServerError)
			}
		}()
		h.ServeHTTP(w, r)
	})
}
