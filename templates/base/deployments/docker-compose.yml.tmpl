services:
  app:
    build:
      context: ..
      dockerfile: deployments/Dockerfile
    environment:
      APP_ADDR: ":8080"
    ports:
      - "8080:8080"
    depends_on:
      - db
  db:
    image: postgres:16-alpine
    environment:
      POSTGRES_USER: {{.Name}}
      POSTGRES_PASSWORD: {{.Name}}
      POSTGRES_DB: {{.Name}}
    ports:
      - "5432:5432"
